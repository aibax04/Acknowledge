# Copy this file to .env and fill in your values.
# This is the only env file; it lives in the backend directory.

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/acknowledge_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=Acknowledge_db

SECRET_KEY=change_me_to_something_very_secure_in_production
ALLOWED_ORIGINS=https://your-domain.com,http://your-ip-address

# Microsoft OAuth (Optional)
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Senior signup: secret key required to create a Senior Leadership account
SENIOR_SIGNUP_KEY=your-secret-senior-signup-key
