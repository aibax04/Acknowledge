# Copy this file to .env and fill in your values.
# This is the only env file; it lives in the backend directory.

# Database (required for login and all app features)
# - If running backend in Docker (e.g. docker-compose.prod.yml), use host "db" and ensure the db service is running.
# - If running backend on the host (e.g. uvicorn), use host "localhost" and ensure Postgres is listening on 5432.
# "Connection to database failure" on login usually means: Postgres not running, or wrong host/port in DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/acknowledge_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=Acknowledge_db

SECRET_KEY=change_me_to_something_very_secure_in_production
# Comma-separated; include your frontend origin(s) for CORS (required for postflow.panscience.ai)
ALLOWED_ORIGINS=https://postflow.panscience.ai,http://postflow.panscience.ai,http://localhost:5500

# Microsoft OAuth (Optional)
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Senior signup: secret key required to create a Senior Leadership account
SENIOR_SIGNUP_KEY=your-secret-senior-signup-key
